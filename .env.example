# ============================================================
# Copie este arquivo para ".env" e ajuste os valores se precisar.
# Padrão de nomes: <SERVICO>_DB_USER / _DB_PASSWORD / _DB_NAME / _DB_PORT / _APP_PORT
# ============================================================

# --- kafka ---
# Porta exposta no host (debug local com kafkacat, scripts, etc).
# Dentro da rede do compose os serviços usam kafka:9092.
KAFKA_HOST_PORT=9094

# --- auth ---
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass
AUTH_DB_NAME=auth_db
AUTH_DB_PORT=5433
AUTH_APP_PORT=3001

# --- cart ---
CART_DB_USER=cart_user
CART_DB_PASSWORD=cart_pass
CART_DB_NAME=cart_db
CART_DB_PORT=5434
CART_APP_PORT=3002

# --- catalog ---
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=catalog_pass
CATALOG_DB_NAME=catalog_db
CATALOG_DB_PORT=5435
CATALOG_APP_PORT=3003

# --- inventory ---
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_pass
INVENTORY_DB_NAME=inventory_db
INVENTORY_DB_PORT=5436
INVENTORY_APP_PORT=3004

# --- notification ---
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_pass
NOTIFICATION_DB_NAME=notification_db
